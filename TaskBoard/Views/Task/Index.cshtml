@model List<TaskBoard.Models.TaskDTO>
@{
    ViewData["Title"] = "Tasks";
}

<div class="col-6 text-end">
    <a asp-action="Add" class="btn btn-primary">
        <i class="bi bi-file-plus"></i>Add new category
    </a>
</div>

<h1>Task List</h1>

@if (Model == null || !Model.Any())
{
    <p>No tasks available.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var task in Model)
            {
                <tr>
                    <td>@task.Title</td>
                    <td>@task.Description</td>
                    <td>@task.CurrentStatus</td>
                    <td>
                        <div class="w-75 btn-group" role="group">
                            <a asp-controller="Task" asp-action="Edit" asp-route-id="@task.Id" class="btn btn-primary mx-2">
                                <i class="bi bi-pencil-square"></i>Edit
                            </a>
                            <form asp-controller="Task" asp-action="Delete" asp-route-id="@task.Id" class="btn btn-primary mx-2">
                                <button type="submit" class="btn-danger">Delete</button>
                                
                            </form'>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}


